{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FM",
  "version": "0.1.0",
  "identifier": "com.akinozgen.fm",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "FM",
        "width": 800,
        "height": 600,
        "minWidth": 760,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica", "acrylic", "hudWindow"],
          "state": "followsWindowActiveState",
          "radius": null,
          "color": null
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
